#!/usr/bin/env sh
# kara — session launcher for the kara desktop environment
#
# Run this from a TTY or as the Exec= line in a wayland-session
# .desktop file instead of `kara-gate` directly. It wraps the
# compositor in `dbus-run-session` so every child process
# (kara-gate, kara-beautify, xdg-desktop-portal, Firefox/Floorp,
# GTK apps, ...) sees a single user D-Bus session bus.
#
# Why this matters:
#   On systemd-based distros, `dbus.socket` is started automatically
#   as a user unit at login. On OpenRC / runit / s6 / dinit (Artix,
#   Void, Gentoo, Alpine), nothing starts a user session bus by
#   default — you either wrap `startx`/`sway`/`<compositor>` in
#   `dbus-run-session` yourself, or you have no session bus at all.
#
#   Without a session bus:
#     - xdg-desktop-portal can't register its service → no portal
#     - Firefox / Floorp can't receive live color-scheme updates
#       (kara-beautify's `gsettings set color-scheme prefer-dark`
#       writes to dconf, but the portal signal chain that tells
#       running GTK/Firefox apps "flip now" is broken)
#     - notification daemons, clipboard managers, secret services,
#       and anything else that speaks D-Bus silently degrades
#
#   This wrapper guarantees a session bus exists for the lifetime of
#   your kara session on every init system.
#
# Usage:
#   From a TTY:            kara
#   From a display mgr:    exec=kara   (session/kara.desktop wires this)
#
# Args after `kara` are forwarded to kara-gate as-is, so
# `kara --log-level debug` works.

set -Eeu

# ─── Session theme environment ────────────────────────────────────────
# Preload kara-beautify's generated session env (fzf color opts,
# XCURSOR vars, anything else kara-theme/render/session.rs emits)
# so child processes inherit the right values from frame one.
# Silently skipped if kara-beautify has never been run.
_kara_session_theme="${XDG_STATE_HOME:-$HOME/.local/state}/kara/generated/session-theme.sh"
if [ -f "$_kara_session_theme" ]; then
    # shellcheck disable=SC1090
    . "$_kara_session_theme"
fi
unset _kara_session_theme

# ─── Wayland + toolkit hints ──────────────────────────────────────────
# kara-gate.conf's [environment] block sets these too, but clients
# launched BEFORE kara-gate parses its config (e.g. xdg-desktop-portal
# spawned by the first portal D-Bus call) need them earlier — so we
# export them here, and kara-gate's block acts as a no-op override.
export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-kara}"
export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
export QT_QPA_PLATFORM="${QT_QPA_PLATFORM:-wayland}"
export MOZ_ENABLE_WAYLAND="${MOZ_ENABLE_WAYLAND:-1}"
export ELECTRON_OZONE_PLATFORM_HINT="${ELECTRON_OZONE_PLATFORM_HINT:-wayland}"
export _JAVA_AWT_WM_NONREPARENTING="${_JAVA_AWT_WM_NONREPARENTING:-1}"

# ─── D-Bus session ────────────────────────────────────────────────────
# Two scenarios:
#
#   1. A user-session D-Bus is ALREADY running (Artix dinit starts one
#      at boot via the `dbus` service, exposed at
#      $XDG_RUNTIME_DIR/bus; systemd distros do the same via
#      dbus.socket). In this case we join that bus. It persists across
#      kara restarts — kara-whisper keeps its `org.freedesktop.Notifications`
#      registration across compositor reloads, and notify-send from
#      any terminal (started before, during, or after kara) reaches
#      the same bus.
#
#   2. No user bus is running. Then we fall back to `dbus-run-session`,
#      which spawns a throwaway private daemon keyed to this kara
#      process tree. Works, but every compositor restart cuts a new
#      socket — terminals opened before the restart go stale and
#      notify-send starts failing with "Could not connect: No such
#      file or directory". That was the whole kara-gate-spawned bus
#      problem. Skipping the wrapper when the system bus exists
#      avoids the stale-address trap entirely.
#
# `DBUS_SESSION_BUS_ADDRESS` takes precedence if set (e.g. the
# display manager already resolved it). Otherwise probe
# `$XDG_RUNTIME_DIR/bus` directly — that's where dbus-daemon
# --session installs by default on both systemd and dinit.
_kara_bus="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/bus"
if [ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ]; then
    # Already resolved; just exec.
    exec kara-gate "$@"
elif [ -S "$_kara_bus" ]; then
    export DBUS_SESSION_BUS_ADDRESS="unix:path=$_kara_bus"
    exec kara-gate "$@"
elif command -v dbus-run-session >/dev/null 2>&1; then
    # No user-session bus running; spin up a private one.
    # Every kara restart will cut a new socket — keep that in mind
    # when opening terminals from outside the compositor.
    exec dbus-run-session -- kara-gate "$@"
else
    echo "kara: warning: no session D-Bus and dbus-run-session missing" >&2
    echo "kara:          install the 'dbus' package or enable the"      >&2
    echo "kara:          user-session bus for live theme switching,"    >&2
    echo "kara:          notifications, and portal file pickers."       >&2
    exec kara-gate "$@"
fi
